    { "path": "../../libs/core/tsconfig.lib.json" },
    { "path": "../../libs/math/tsconfig.lib.json" },
    { "path": "../../libs/misc/tsconfig.lib.json" },
    { "path": "../../libs/binary/tsconfig.lib.json" },
    { "path": "../../libs/physics3d/tsconfig.lib.json" },
    { "path": "../../libs/character-controller-3d/tsconfig.lib.json" },
    { "path": "../../libs/animation-controller/tsconfig.lib.json" }
