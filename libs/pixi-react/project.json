{
  "name": "@lagless/pixi-react",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "commands": [
          "tsc --build tsconfig.lib.json",
          "cp -r src/lib/virtual-joystick/textures dist/lib/virtual-joystick/textures"
        ],
        "cwd": "libs/pixi-react",
        "parallel": false
      },
      "cache": true,
      "inputs": ["production", { "dependentTasksOutputFiles": "**/*.d.ts" }],
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
