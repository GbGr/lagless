{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "out-tsc",
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "lib": ["es2022", "dom"],
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts"],
  "references": [
    {
      "path": "../react"
    },
    {
      "path": "../core"
    }
  ]
}
