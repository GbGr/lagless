{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../core/tsconfig.lib.json" },
    { "path": "../binary/tsconfig.lib.json" },
    { "path": "../misc/tsconfig.lib.json" },
    { "path": "../net-wire/tsconfig.lib.json" }
  ],
  "exclude": [
    "vite.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
